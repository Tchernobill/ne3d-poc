{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "strict": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib":["DOM", "ES5", "ES6", "ES7"],
    "typeRoots": ["types", "node_modules/@types"]
  },
  "include":["src/**/*.ts", "src/**/*.svelte",  "main.ts", "types"]
}
